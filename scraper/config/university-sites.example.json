{
  "crawlDefaults": {
    "maxRequestsPerCrawl": 40,
    "maxDepth": 1,
    "navigationTimeoutSecs": 30,
    "requestHandlerTimeoutSecs": 45,
    "respectRobotsTxtFile": true,
    "maxLinksPerPage": 100,
    "minTextLength": 40,
    "includeHtml": true,
    "contentSelectors": [
      "main",
      "#content",
      ".main-content",
      "article",
      ".page-content",
      "[role='main']"
    ],
    "stripQueryParams": [
      "utm_source",
      "utm_medium",
      "utm_campaign",
      "utm_term",
      "utm_content",
      "fbclid",
      "gclid"
    ],
    "blockedExtensions": [
      ".pdf",
      ".doc",
      ".docx",
      ".xls",
      ".xlsx",
      ".ppt",
      ".pptx",
      ".zip",
      ".jpg",
      ".jpeg",
      ".png"
    ]
  },
  "siteDefaults": {
