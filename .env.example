# Frontend: Vercel exposes only variables prefixed with VITE_ to browser code.
# Leave this blank locally if you want Vite to use the dev proxy in vite.config.js.
VITE_API_BASE_URL=http://localhost:3001

# Backend: Render environment variables.
ALLOWED_ORIGINS=http://localhost:5173
CLIENT_URL=http://localhost:5173
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/<database>?retryWrites=true&w=majority
MONGODB_DB_NAME=campus-resource-manager
AUTH_TOKEN_SECRET=replace-with-a-long-random-string
