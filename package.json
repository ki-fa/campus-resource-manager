{
  "name": "campus-resource-manager",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "nodemon server/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server/index.js",
    "scrape:crawl": "node scraper/crawl.mjs",
    "scrape:validate": "node scraper/crawl.mjs --dry-run",
    "scrape:add-sites": "node scraper/add-sites.mjs",
    "scrape:install-browser": "npx playwright install chromium",
    "scrape:parse": "python scraper/normalize.py",
    "scrape:parse:python3": "python3 scraper/normalize.py"
  },
  "dependencies": {
    "crawlee": "^3.15.3",
    "express": "^5.1.0",
    "playwright": "^1.54.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.10",
    "vite": "^7.0.0"
  }
}
